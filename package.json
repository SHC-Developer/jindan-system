{
  "name": "jindan-system",
  "private": true,
  "version": "1.0.4",
  "description": "KDVO 안전진단팀 협업 웹앱 (Electron 데스크톱)",
  "author": "KDVO",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:electron-vite": "vite --port=3000 --host=0.0.0.0 --strictPort",
    "build": "vite build",
    "build:web": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron",
    "lint": "tsc --noEmit",
    "set-user": "tsx scripts/set-user-firestore.ts",
    "set-storage-cors": "tsx scripts/set-storage-cors.ts",
    "build:electron-main": "tsc -p electron/tsconfig.json && tsc -p electron/tsconfig.preload.json",
    "generate:tray-icon": "node scripts/generate-tray-icon.mjs",
    "dev:electron": "npm run generate:tray-icon && npm run build:electron-main && concurrently \"npm run dev:electron-vite\" \"wait-on http://localhost:3000 && electron .\"",
    "build:electron": "npm run generate:tray-icon && cross-env ELECTRON=true vite build && npm run build:electron-main && electron-builder",
    "prebuild:electron": "node -e \"try { require('fs').rmSync('release', { recursive: true, force: true }); } catch (e) {}\""
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tiptap/extension-color": "^3.20.0",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-text-style": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "firebase": "^11.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "firebase-admin": "^13.0.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.1.14",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.kdvo.jindan-system",
    "productName": "KDVO 안전진단팀",
    "icon": "public/app-icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "icon": "public/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "KDVO 안전진단팀 ${version}",
      "include": "build/installer.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "SHC-Developer",
      "repo": "jindan-system",
      "releaseType": "release"
    }
  }
}
